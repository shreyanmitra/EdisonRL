{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EdisonRL Scenario",
  "type": "object",
  "required": [
    "square_types",
    "scenarios"
  ],
  "properties": {
    "metadata": {
      "type": "object"
    },
    "square_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "reward_on_enter",
          "terminal",
          "blocked",
          "wait_steps",
          "force_action"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "reward_on_enter": {
            "type": "integer",
            "minimum": -32767,
            "maximum": 32767
          },
          "terminal": {
            "type": "boolean"
          },
          "blocked": {
            "type": "boolean"
          },
          "wait_steps": {
            "type": "integer",
            "minimum": 0,
            "maximum": 20
          },
          "force_action": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "forward",
              "spin_left",
              "spin_right",
              null
            ]
          },
          "color_hex": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "id_bars",
          "rows",
          "cols",
          "start",
          "cells"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "id_bars": {
            "type": "integer",
            "minimum": 1,
            "maximum": 7
          },
          "rows": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "cols": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "start": {
            "type": "object",
            "required": [
              "row",
              "col",
              "heading"
            ],
            "properties": {
              "row": {
                "type": "integer",
                "minimum": 0
              },
              "col": {
                "type": "integer",
                "minimum": 0
              },
              "heading": {
                "type": "integer",
                "minimum": 0,
                "maximum": 3
              }
            }
          },
          "cells": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 31
              }
            }
          }
        }
      }
    }
  }
}
